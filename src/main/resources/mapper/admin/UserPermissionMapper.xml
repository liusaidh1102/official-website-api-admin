<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="weilai.team.officialWebSiteApi.mapper.admin.UserPermissionMapper">

    <resultMap id="BaseResultMap" type="weilai.team.officialWebSiteApi.entity.admin.DO.UserPermission">
            <id property="id" column="id" jdbcType="BIGINT"/>
            <result property="userId" column="user_id" jdbcType="BIGINT"/>
            <result property="authority" column="authority" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        <if test="true">
            id,user_id,authority
        </if>
    </sql>

    <select id="getAuthorityByUserId" resultType="string">
        select authority
        from user_permission
        where user_id = #{userId,jdbcType=NUMERIC}
    </select>

    <delete id="deleteByUserIdAndAuthority">
        delete
        from user_permission
        where user_id = #{userId,jdbcType=NUMERIC}
          AND authority = #{authority,jdbcType=VARCHAR}
    </delete>

    <delete id="deleteByUserIdIn">
        delete from user_permission
        where
        user_id in
        <foreach collection="userIdList" item="item" open="(" close=")" separator=",">
            #{item,jdbcType=NUMERIC}
        </foreach>
    </delete>

</mapper>
