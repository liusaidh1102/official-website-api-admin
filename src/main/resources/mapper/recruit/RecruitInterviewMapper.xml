<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="weilai.team.officialWebSiteApi.mapper.recruit.RecruitInterviewMapper">


    <insert id="insertInterviewUser">
        INSERT INTO recruit_interview(user_id,name,grade) VALUES (#{userId},#{name},#{grade})
    </insert>


    <select id="selectMyPage" resultMap="selectRecruitInterviewMap">
        SELECT ri.id,
               ri.grade,
               ri.user_id,
               ri.name,
               ri.place,
               ri.round,
               ri.start_time,
               ri.end_time,
               ri.interview_status,
               ri.first_hr,
               ri.second_hr,
               ri.third_hr
        from recruit_interview ri
                 left join user u on u.id = ri.user_id
            ${ew.customSqlSegment}
    </select>

    <select id="selectMyList" resultMap="selectRecruitInterviewMap">
        SELECT ri.id,
               ri.grade,
               ri.user_id,
               ri.name,
               ri.place,
               ri.round,
               ri.start_time,
               ri.end_time,
               ri.interview_status,
               ri.first_hr,
               ri.second_hr,
               ri.third_hr
        from recruit_interview ri ${ew.customSqlSegment}
    </select>


    <resultMap id="selectRecruitInterviewMap" type="weilai.team.officialWebSiteApi.entity.recruit.VO.RecruitInterviewVO">
        <collection property="firstHr" column="first_hr" select="weilai.team.officialWebSiteApi.mapper.recruit.RecruitInterviewMapper.getHrById"></collection>
        <collection property="secondHr" column="second_hr" select="weilai.team.officialWebSiteApi.mapper.recruit.RecruitInterviewMapper.getHrById"></collection>
        <collection property="thirdHr" column="third_hr" select="weilai.team.officialWebSiteApi.mapper.recruit.RecruitInterviewMapper.getHrById"></collection>
    </resultMap>




</mapper>