<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="weilai.team.officialWebSiteApi.mapper.admin.UserGroupLeaderMapper">

    <resultMap id="BaseResultMap" type="weilai.team.officialWebSiteApi.entity.admin.DO.UserGroupLeader">
            <id property="id" column="id" jdbcType="BIGINT"/>
            <result property="groupLeaderId" column="group_leader_id" jdbcType="BIGINT"/>
            <result property="groupPostiton" column="group_postiton" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        <if test="true">
            id,group_leader_id,group_postiton
        </if>
    </sql>

    <select id="selectGroupLeaderIdByGroupPostiton" resultType="long">
        select group_leader_id
        from user_group_leader
        where group_postiton = #{groupPostiton,jdbcType=VARCHAR}
    </select>

    <delete id="delByGroupLeaderIdIn">
        delete from user_group_leader
        where
        group_leader_id in
        <foreach collection="groupLeaderIdList" item="item" open="(" close=")" separator=",">
            #{item,jdbcType=NUMERIC}
        </foreach>
    </delete>
    <delete id="delByGroupLeaderIdAndGroupPostiton">
        delete
        from user_group_leader
        where group_leader_id = #{groupLeaderId,jdbcType=NUMERIC}
          AND group_postiton = #{groupPostiton,jdbcType=VARCHAR}
    </delete>
</mapper>
