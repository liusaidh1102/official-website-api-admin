<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="weilai.team.officialWebSiteApi.mapper.postComment.PostCommentOneMapper">

    <resultMap id="BaseResultMap" type="weilai.team.officialWebSiteApi.entity.postComment.DO.PostCommentOne">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="postId" column="post_id" jdbcType="BIGINT"/>
        <result property="commentUser" column="comment_user" jdbcType="BIGINT"/>
        <result property="commentTxt" column="comment_txt" jdbcType="VARCHAR"/>
        <result property="commentTime" column="comment_time" jdbcType="TIMESTAMP"/>
        <result property="likeCount" column="like_count" jdbcType="BIGINT"/>
        <result property="deleteFlag" column="delete_flag" jdbcType="TINYINT"/>
    </resultMap>

    <sql id="Base_Column_List">
        <if test="true">
            id,post_id,comment_user,
            comment_txt,comment_time,like_count,
            delete_flag
        </if>
    </sql>

    <select id="selectAllByPostId" resultType="weilai.team.officialWebSiteApi.entity.postComment.VO.CommentOneVO">
        select * from(
        select post_comment_one.id                                                             as commentId,
               comment_user                                                                    as userId,
               comment_txt                                                                     as commentTxt,
               comment_time                                                                    as commentTime,
               like_count                                                                      as likeCount,
               if(comment_user != #{userId}, false, true)                                      as isMyComment,
               (select count(*) from post_comment_all
                                where post_comment_all.comment_id = post_comment_one.id
                                  and post_comment_all.delete_flag = 0)                        as commentCount
        from post_comment_one
        where post_id = #{postId}
          and post_comment_one.delete_flag = 0
        group by post_comment_one.id) as t
        order by commentTime desc
    </select>

    <select id="selectCountByPostId" resultType="java.lang.Integer">
        select count(*) from post_comment_one where post_id = #{postId} and delete_flag = 0
    </select>
    <select id="selectPostId" resultType="java.lang.Integer" parameterType="java.lang.Long">
        select post_id from post_comment_one where id = #{commentId}
    </select>

    <update id="updateLikeCountById">
        update post_comment_one
        set like_count = #{likeCount}
        where id = #{id,jdbcType=NUMERIC}
    </update>

    <delete id="softDeleteClear">
        delete from post_comment_one where delete_flag = 1;
    </delete>

    <select id="selectIdByPostId" resultType="Integer">
        select id
        from post_comment_one
        where post_id = #{postId,jdbcType=NUMERIC}
    </select>

</mapper>
